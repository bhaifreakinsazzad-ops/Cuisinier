# ── Supabase (client-side, safe to expose) ────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Supabase (server-side only — NEVER prefix with VITE_) ─────────────────────
# Used only by Vercel serverless functions (/api/*). Never set in browser builds.
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin auth (server-side only) ────────────────────────────────────────────
# Strong password for the admin panel. Server-side only — never expose to browser.
ADMIN_PASSWORD=
# Random secret (32+ chars) used to HMAC-sign admin session tokens.
ADMIN_SESSION_SECRET=
# Session lifetime in minutes (default: 480 = 8 hours)
ADMIN_SESSION_TTL_MINUTES=480

# ── Local dev fallback ONLY (leave blank in production) ──────────────────────
# If ADMIN_PASSWORD is not set server-side (local `vite dev`), this is used as
# a client-side fallback. Must be empty in Vercel production deployments.
VITE_ADMIN_PASSWORD=

# ── Analytics ────────────────────────────────────────────────────────────────
VITE_GA4_MEASUREMENT_ID=
VITE_META_PIXEL_ID=983944370699450
